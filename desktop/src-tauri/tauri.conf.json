{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yunaki",
  "version": "0.1.0",
  "identifier": "app.yunaki.desktop",
  "build": {
    "frontendDist": "../../frontend/out",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist/yunaki-sidecar": "yunaki-sidecar"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://REPLACE-IN-PHASE-E2.example.com/yunaki/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_MINISIGN_PUBLIC_KEY_IN_PHASE_E2",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
