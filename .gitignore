# Secrets — never committed
.env
.env.*
!.env.example

# PII — uploaded documents and test fixtures never reach the repo
uploads/
backend/uploads/
backend/tests/fixtures/*
!backend/tests/fixtures/README.md
backend/tests/.extraction_cache/

