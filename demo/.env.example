# CLAUDE_WORKPLAN.md §1.4 — copy to .env (gitignored) and fill in. Never commit .env.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL_CASES=
ANTHROPIC_API_KEY=
LIVE_MODE=false
DB_PATH=./yunaki.db

# Gmail agent (Workstream A — Jul 22 scope change). DEMO mailbox only, never the firm's.
# Authorize once with: python -m gmail_agent.auth
GMAIL_ADDRESS=
GMAIL_CREDENTIALS_PATH=.secrets/gmail_credentials.json
GMAIL_TOKEN_PATH=.secrets/gmail_token.json
GMAIL_TOPIC=
GMAIL_PUBSUB_SUBSCRIPTION=
GOOGLE_APPLICATION_CREDENTIALS=

# Email agent brain = the yunaki kernel deep-agent loop, model = Gemini
# (make_agent_model; locked stack decision). Requires the yunaki backend
# installed (Python >=3.11) — see README / docs/gmail-agent-setup.md.
GEMINI_API_KEY=
