# Required — vision extraction
GEMINI_API_KEY=your-gemini-api-key

# Optional — Supabase storage (falls back to local disk when unset)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional — Langfuse observability (tracing is a no-op when unset).
# Traces carry content hashes, timings, token counts, and field statistics —
# never document images or extracted values.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=           # default https://cloud.langfuse.com; set to your self-hosted URL to keep traces on-prem

# Optional overrides
GEMINI_MODEL=            # default set in backend/app/config.py
POPULATE_HEADED=         # default false (headless fill + downloadable PDF artifact);
                         # set true to watch the browser fill live (artifact becomes a PNG)
