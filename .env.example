# Required — vision extraction
GEMINI_API_KEY=your-gemini-api-key

# Optional — Supabase storage (falls back to local disk when unset)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional overrides
GEMINI_MODEL=            # default set in backend/app/config.py
POPULATE_HEADED=true     # show the browser during form population
